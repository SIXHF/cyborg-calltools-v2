# WebSocket Server
WS_PORT=8766
WS_HOST=0.0.0.0

# Database (Magnus Billing MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_USER=mbillingUser
DB_PASS=
DB_NAME=mbilling

# Asterisk AMI
AMI_HOST=127.0.0.1
AMI_PORT=5038
AMI_USER=
AMI_PASS=

# Whisper GPU Server (via SSH tunnel)
WHISPER_GPU_URL=http://localhost:8765
WHISPER_GPU_API_KEY=

# Telnyx API (CNAM lookups)
TELNYX_API_KEY=

# IPQualityScore API (fraud detection)
IPQS_API_KEY=

# ElevenLabs API (transcription)
ELEVENLABS_API_KEY=

# Allowed WebSocket origins (comma-separated)
WS_ALLOWED_ORIGINS=https://sip.osetec.net

# Permissions file path
PERMISSIONS_FILE=/opt/calltools-v2-permissions.json

# Audit log path
AUDIT_LOG_FILE=/opt/calltools-v2-audit.log

# Max connections per user
MAX_CONNECTIONS_PER_USER=3

# Session TTL in seconds (5 minutes)
SESSION_RESUME_TTL=300
